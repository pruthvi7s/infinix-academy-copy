
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data != null && userDoc.data.role == 'admin';
    }

    // --- Student Data Rules ---
    
    // Validate student data structure
    function isValidStudent(data) {
      // Enforce size limits on all string fields to prevent DoS
      return data.name is string && data.name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             (data.experiencePoints is number || !('experiencePoints' in data)) &&
             (data.savedCourses is list || !('savedCourses' in data)) &&
             (data.completedLessons is map || !('completedLessons' in data)) &&
             (data.completedProjects is list || !('completedProjects' in data));
    }

    match /students/{studentId} {
      allow read: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId) && isValidStudent(request.resource.data);
      allow update: if isOwner(studentId) && isValidStudent(request.resource.data);
      allow delete: if false;
    }
    
    match /students/{document=**} {
        allow list: if isAdmin();
    }

    // --- User Role Rules ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['role']) && request.resource.data.role == 'student';
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role; // Cannot change role
      allow delete: if false;
    }
    
    // --- Message Rules ---
    match /messages/{messageId} {
        allow create: if isAuthenticated();
        allow read, delete: if isAdmin();
    }
    
    match /messages/{document=**} {
        allow list: if isAdmin();
    }
    
    // --- Payment Request Rules ---
    match /paymentRequests/{requestId} {
        allow create: if isAuthenticated();
        allow read, update: if isAdmin();
    }

    match /paymentRequests/{document=**} {
        allow list: if isAdmin();
    }
  }
}
