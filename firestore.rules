
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the requesting user is an admin by looking at their role
    // in their own user document.
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Student Data Rules ---
    match /students/{studentId} {
      // Admins have full read/write access to all student documents.
      allow read, write: if isAdmin();
      
      // A student can only read, create, or update their OWN document. They cannot delete it.
      allow read, create, update: if request.auth.uid == studentId;
      allow delete: if false; // Students cannot delete their own records.
    }
    
    // Admins need list access on the collection to fetch all students for the dashboard.
    match /students/{document=**} {
        allow list: if isAdmin();
    }

    // --- User Role Rules ---
    match /users/{userId} {
      // A user can read their own user document. This is required for the isAdmin() function to work.
      allow read: if request.auth.uid == userId;
      
      // A user can create their own user document upon sign-up.
      allow create: if request.auth.uid == userId;

      // A user can only update their own document.
      allow update: if request.auth.uid == userId;
      
      // Deleting user role documents is not allowed from the client to prevent privilege escalation issues.
      allow delete: if false;
    }
    
    // --- Message Rules ---
    match /messages/{messageId} {
        // Any authenticated user can create (send) a message.
        allow create: if request.auth != null;
        // Only admins can read or delete messages.
        allow read, delete: if isAdmin();
    }
    
    // Admins need list access on the collection to fetch all messages for the dashboard.
    match /messages/{document=**} {
        allow list: if isAdmin();
    }
    
    // --- Payment Request Rules ---
    match /paymentRequests/{requestId} {
        // Any authenticated user can create a payment request.
        allow create: if request.auth != null;
        // Only admins can read or update payment requests (to approve them).
        allow read, update: if isAdmin();
    }

    // Admins need list access on the collection to fetch all payment requests.
    match /paymentRequests/{document=**} {
        allow list: if isAdmin();
    }
  }
}
